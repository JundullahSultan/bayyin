<%- include('partials/header') %>

<div style="max-width: 400px; margin: 4rem auto; background: white; padding: 2rem; border-radius: 20px; border: 1px solid #ede5da; text-align: center;">
  <h1 style="font-size: 1.8rem; margin-bottom: 1.5rem;">Admin Login</h1>
  
  <% if (error) { %>
    <div style="background: #fee2e2; color: #991b1b; padding: 0.75rem; border-radius: 10px; margin-bottom: 1.5rem; font-size: 0.9rem;">
      <%= error %>
    </div>
  <% } %>

  <form action="/admin/login" method="POST" style="display: flex; flex-direction: column; gap: 1rem;">
    <input type="text" name="username" placeholder="Username" required 
           style="padding: 0.8rem 1rem; border: 1px solid #ede5da; border-radius: 10px; font-size: 1rem; outline: none; background: #fdf9f2;">
    
    <input type="password" name="password" placeholder="Password" required 
           style="padding: 0.8rem 1rem; border: 1px solid #ede5da; border-radius: 10px; font-size: 1rem; outline: none; background: #fdf9f2;">
    
    <button type="submit" style="background: #8b5a2b; color: white; border: none; padding: 0.8rem; border-radius: 10px; font-weight: 600; font-size: 1rem; cursor: pointer; margin-top: 0.5rem;">
      Login
    </button>
  </form>
</div>

<%- include('partials/footer') %>